# Copy to .env and adjust. NEVER commit real secrets.

# Public base URL of the deployed service (used in report/badge links).
# On Railway this is auto-derived from RAILWAY_PUBLIC_DOMAIN if unset.
PREFLIGHT_PUBLIC_BASE_URL=https://preflight.example.com

# SQLite report storage
PREFLIGHT_DB_PATH=preflight.db

# Local development ONLY: allow http:// and localhost targets
PREFLIGHT_ALLOW_INSECURE_TARGETS=false

# Abuse protection
PREFLIGHT_RATE_LIMIT_PER_MINUTE=10

# --- Payments (x402) — optional; service runs free-mode without these -------
# Enable after installing the payments extra:  pip install '.[payments]'
PREFLIGHT_PAYMENTS_ENABLED=false
PREFLIGHT_PAY_TO_ADDRESS=
PREFLIGHT_AUDIT_PRICE_USD=$0.05
# From https://web3.okx.com/onchainos/dev-portal
PREFLIGHT_OKX_API_KEY=
PREFLIGHT_OKX_SECRET_KEY=
PREFLIGHT_OKX_PASSPHRASE=

